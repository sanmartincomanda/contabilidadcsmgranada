rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isMaster() {
      return signedIn() && request.auth.token.email == 'luis.s.97@hotmail.com';
    }

    match /integraciones_privadas/{document=**} {
      allow read, write: if false;
    }

    match /usuarios_sistema/{userId} {
      allow read: if signedIn() && (isMaster() || request.auth.token.email == userId);
      allow write: if isMaster();
    }

    match /diferencias_caja/{document} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if isMaster();
    }

    match /abonos_diferencias_caja/{document} {
      allow read: if signedIn();
      allow write: if isMaster();
    }

    match /{collection}/{document=**} {
      allow read, write: if signedIn()
        && collection != 'integraciones_privadas'
        && collection != 'usuarios_sistema'
        && collection != 'diferencias_caja'
        && collection != 'abonos_diferencias_caja';
    }
  }
}
